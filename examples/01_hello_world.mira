// 基本的 Hello World 示例
debug_print("Hello, World!");

// 使用字符串插值
let name = "MiraScript";
debug_print("Hello from $name!");

// 使用不同类型的字符串字面量
debug_print('Single quotes work too!');
debug_print(`Backticks support
multiline strings`);

// 逐字字符串示例
debug_print(@"This is a verbatim string with \n literal backslashes"@);
