let mut cache = ();

fn fib(n) {
  if n <= 2 {
    return n;
  }
  if n in cache {
    return cache[n];
  }
  let result = fib(n - 1) + fib(n - 2);
  // MiraScript values are immutable, so we need to create a new cache entry
  cache = (..cache, `$n`: result);
  result
}

fn main() {
  let n = 10; // Example input
  let result = fib(n);
  debug_print("Fibonacci of $n is $result");
}

main();

cache // Return the cache from script for inspection