t_eq(2 + 2, 4);
t_eq('   1' + '2  ', 3);
t_eq('1' + '', 1);
t_eq('Hello, ' + 'World!', nan);
t_eq([1] + 2, nan);

t_eq(2 - 1, 1);
t_eq(true - false, 1);
t_eq(nil - '\n', 0);

t_eq(2 * 3, 6);
t_eq(6 / 2, 3);
t_eq(7 % 3, 1);
t_eq((-7) % 3, -1);

t_eq(2^3, 8);
t_eq(2^(-3), 0.125);
t_eq(2^0, 1);
t_eq(0^0, 1);
t_eq((-1)^0.5, nan);
t_eq(0^inf, 0);
t_eq(2^inf, inf);
t_eq(2^(-inf), 0);
