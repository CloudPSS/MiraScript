t_snapshot("", '', ``);
t_snapshot("Hello world");
t_snapshot("\0\r\n\t\b\f\v\\\"\'\`\$\x12\x34\x56\x78\u{1234}\u{12345}");
t_snapshot(@"\0\r\n\t\b\f\v\\\"\'\`\$\x12\x34\x56\x78\u{1234}\u{12345}"@);
let Hello = "Hello";
t_snapshot("$(Hello)
  world${ `!
  ` }");

let strs = ['Hello, World!', '你好，世界！', 'こんにちは、世界！', '안녕하세요, 세계!', '🫱🏾‍🫲🏼🌍'];
for str in strs {
  t_snapshot(str);

  let mut chs = [];
  for ch in str {
    chs = [..chs, ch];
  }

  t_eq(chars(str), chs);
}

t_false('a' in 'a');
t_false('' in 'a');

t_eq(chars(123), ['1', '2', '3']);

let whitespaces = "\t\v\f \u{A0} \n\r\u{FEFF}\u{2028}\u{2029}";
t_eq("$(whitespaces)1$(whitespaces)"::trim(), "1");
t_eq("$(whitespaces)1$(whitespaces)"::trim_start(), "1$(whitespaces)");
t_eq("$(whitespaces)1$(whitespaces)"::trim_end(), "$(whitespaces)1");
