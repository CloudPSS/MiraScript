fn T { true }
fn F { false }
fn N { nil }
fn O { 0 }

if T() {
  t_true(true);
} else {
  t_never();
}
if F() {
  t_never();
} else {
  t_true(true);
}
t_throws(fn {
  if N() { }
});
t_throws(fn {
  if O() { }
});

if !T() {
  t_never();
} else {
  t_true(true);
}
if !F() {
  t_true(true);
} else {
  t_never();
}
t_throws(fn {
  if !N() { }
});
t_throws(fn {
  if !O() { }
});

if !T() {
  t_never();
} else if !F() {
  t_true(true);
} else {
  t_never();
}