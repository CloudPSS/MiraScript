let expected_channels = [(key: 'canvas_0_1020', name: '#wr1'), (key: 'canvas_0_1022', name: '#wr2'), (key: 'canvas_0_1023', name: '#wr3'), (key: 'canvas_0_1024', name: '#P2'), (key: 'canvas_0_1025', name: '#Q2'), (key: 'canvas_0_1026', name: '#P1'), (key: 'canvas_0_1027', name: '#Q1'), (key: 'canvas_0_1028', name: '#P3'), (key: 'canvas_0_1029', name: '#Q3'), (key: 'canvas_0_1042', name: 'vac')];
fn channels($$) {
  fn filter2(v, index, array) { v[1].definition == 'model/CloudPSS/_newChannel' }
  fn mapper1(v, index, array) { (key: @@maybe_chars(v)[0], name: if @@length(v[1].args.Name) !~ 0 { v[1].args.Name } else { v[1].label }) }
  return entries($$.revision.implements.diagram.cells)::filter(filter2)::map(mapper1);
  // # 帮助函数
  fn @@length(x) {
    if type(x) == 'string' { len(chars(x)) } else if type(x) == 'array' { len(x) } else { x.length }
  }
  fn @@maybe_chars(x) {
    if type(x) == 'string' { chars(x) } else { x }
  }
}
t_eq(project::channels(), expected_channels);

fn channels_opt($$) {
  values($$.revision.implements.diagram.cells)::filter_map(fn {
    if it.definition is not 'model/CloudPSS/_newChannel' {
      return nil;
    }

    (key: it.id, name: if it.args.Name !~ '' { it.args.Name } else { it.label })
  })
}
t_eq(project::channels_opt(), expected_channels);
