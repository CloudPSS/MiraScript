t_throws(fn { to_json() });
t_eq(to_json(sin), nil);
t_eq(to_json(nil), 'null');
t_eq(to_json(true), 'true');
t_eq(to_json(false), 'false');
t_eq(to_json(nan), 'null');
t_eq(to_json(inf), 'null');
t_eq(to_json(-inf), 'null');
t_eq(to_json(0), '0');
t_eq(to_json(0.1), '0.1');
t_eq(to_json(-0), '0');
t_eq(to_json(1), '1');
t_eq(to_json(1.5), '1.5');
t_eq(to_json((1, nan, inf, -inf)), '{"0":1,"1":null,"2":null,"3":null}');
t_eq(to_json("Hello, World!"), '"Hello, World!"');
t_eq(to_json("é"), '"é"');
t_eq(to_json([]), '[]');

t_eq(to_json(v_module), '{}');
mod test {
  pub const @C = 1;
  pub let mut i = 1;
  pub let b = true;
  pub let n = nil;
  pub let s = "Hello, World!";
  let hidden = 1;
  pub fn f() {
    i += hidden;
  }
  mod hidden_mod {
    pub let x = 2;
  }
  pub mod m {
    pub let y = 3;
  }
}
t_eq(to_json(test), '{"@C":1,"i":1,"b":true,"n":null,"s":"Hello, World!","m":{"y":3}}');
test.f();
t_eq(to_json(test), '{"@C":1,"i":2,"b":true,"n":null,"s":"Hello, World!","m":{"y":3}}');

if has_extern {
  t_eq(to_json(v_extern), '{}');
}

t_eq(from_json('null'), nil);
t_eq(from_json('true'), true);
t_eq(from_json('false'), false);
t_eq(from_json(@'"\ud83e\udece"'@), '🫎');
t_eq(from_json(@'"\u0000"'@), '\0');
t_eq(from_json('[1, 2, "3", "NaN"]'), [1, 2, "3", "NaN"]);
t_eq(from_json('{"a": 1, "b": 2, "c": true, "d": null }'), (a: 1, b: 2, c: true, d: nil));
t_eq(from_json('{"0": "X"}'), ("X",));
t_eq(from_json('  "x"  '), 'x');
t_eq(from_json('x', sin), sin);
t_throws(fn { from_json(nil) });
t_throws(fn { from_json(sin) });
t_throws(fn { from_json('n') });
t_throws(fn { from_json() });
t_throws(fn { from_json('') });
t_throws(fn { from_json(`'a'`) });
t_throws(fn { from_json(`NaN`) });
t_throws(fn { from_json(`Infinity`) });
t_throws(fn { from_json(`-Infinity`) });
t_throws(fn { from_json(`{"x":NaN}`) });
t_throws(fn { from_json(`{"x":nan}`) });
t_throws(fn { from_json(`{"x":1,}`) });
t_throws(fn { from_json(`{a:1}`) });
t_throws(fn { from_json(`{} // Comment is not allowed in JSON`) });
t_throws(fn { from_json(`{} /* And this */`) });

let values = [0, 1, 2, random(), [1, 2, 3], [random(), 'x', '🫎'], (random(), 'x', '🫎'), (name: "Alice", age: 30, is_student: false, scores: [95.5, 88.0, 76.5], address: (street: "123 Main St", city: "Wonderland", zip: "12345"), hobbies: ["reading", "chess", "hiking"], metadata: nil)];
for v in values {
  t_eq(v::to_json()::from_json(), v);
}