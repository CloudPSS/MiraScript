t_eq(matrix.zeros(2, 3), [[0, 0, 0], [0, 0, 0]]);
t_eq(matrix.zeros([2, 3]), [[0, 0, 0], [0, 0, 0]]);

t_eq(matrix.zeros(), []);
t_eq(matrix.zeros([]), []);
t_eq(matrix.zeros([1, -1]), [[]]);
t_eq(matrix.zeros([1, nan]), [[]]);
t_throws(fn {
  matrix.zeros([1, inf]);
});

t_eq(matrix.ones(2, 3), [[1, 1, 1], [1, 1, 1]]);

t_eq(matrix.identity(), []);
t_eq(matrix.identity(0), []);
t_eq(matrix.identity(3), [[1, 0, 0], [0, 1, 0], [0, 0, 1]]);
t_eq(matrix.identity([3]), [[1, 0, 0], [0, 1, 0], [0, 0, 1]]);
t_throws(fn {
  matrix.identity([inf]);
});
t_throws(fn {
  matrix.identity([1, 2, 3]);
});
t_eq(matrix.identity(2, 3), [[1, 0, 0], [0, 1, 0]]);
