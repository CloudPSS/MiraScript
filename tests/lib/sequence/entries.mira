let mut kv = [];
for (k, v) in entries(('你好', '，', '世界', '！', x: nil)) {
  kv = [..kv, (k, v)];
}
t_eq(kv, [('0', '你好'), ('1', '，'), ('2', '世界'), ('3', '！'), ('x', nil)]);

t_eq(keys([1, 2, 3]), [0, 1, 2]);
t_eq(keys((1, 2, 3)), ['0', '1', '2']);
if has_extern {
  t_eq(keys(v_extern), []);
}
t_eq(keys(v_module), []);
t_throws(fn { keys(fn { }) });

t_eq(values([1, 2, 3]), [1, 2, 3]);
t_eq(values((1, 2, 3)), [1, 2, 3]);
if has_extern {
  t_throws(fn () { values(v_extern) });
}
t_throws(fn () { values(v_module) });
t_throws(fn () { values(fn { }) });

t_eq(entries([nil, 1]), [(0, nil), (1, 1)]);
t_eq(entries([1, 2, 3]), [(0, 1), (1, 2), (2, 3)]);
t_eq(entries((1, 2, 3)), [('0', 1), ('1', 2), ('2', 3)]);
if has_extern {
  t_throws(fn () { entries(v_extern) });
}
t_throws(fn () { entries(v_module) });
t_throws(fn () { entries(fn { }) });
