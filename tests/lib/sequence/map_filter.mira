// 测试 map 函数

// 测试 map 对基本类型的操作
t_eq(map(42, fn (x) { x * 2 }), 84);
t_eq(map("hello", fn (x) { `$x world` }), "hello world");
t_eq(map(true, fn (x) { !x }), false);
t_eq(map(nil, fn (x) { x ?? "default" }), "default");

// 测试 map 对数组的操作
t_eq(map([1, 2, 3], fn (x) { x * 2 }), [2, 4, 6]);
t_eq(map([1, 2, 3], fn (x, i) { x + i }), [1, 3, 5]);
t_eq(map([1, 2, 3], fn (x, i, data) { len(data) }), [3, 3, 3]);
t_eq(map([], fn (x) { x * 2 }), []);

// 测试 map 对记录的操作
t_eq(map((a: 1, b: 2, c: 3), fn (x) { x * 2 }), (a: 2, b: 4, c: 6));
t_eq(map((a: 1, b: 2), fn (x, k) { `$k=$x` }), (a: "a=1", b: "b=2"));
t_eq(map((a: 1, b: 2), fn (x, k, data) { data }), (a: (a: 1, b: 2), b: (a: 1, b: 2)));
t_eq(map((), fn (x) { x * 2 }), ());

// 测试 map 返回 nil 的情况
t_eq(map([1, 2, 3], fn (x) {
  if x > 2 { x } else { nil }
}), [nil, nil, 3]);
t_eq(map((a: 1, b: 2, c: 3), fn (x) {
  if x > 2 { x } else { nil }
}), (a: nil, b: nil, c: 3));

// 测试 map 返回 function 的情况
t_eq(map([1, 2], fn (x) {
  return fn { };
}), [nil, nil]);
t_eq(map((a: 1, b: 2, c: nil), fn (x) {
  return fn { };
}), (a: nil, b: nil, c: nil));

// 测试 filter 函数

// 测试 filter 对基本类型的操作
t_eq(filter(42, fn (x) { x > 40 }), 42);
t_eq(filter(42, fn (x) { x > 50 }), nil);
t_eq(filter("hello", fn (x) { len(chars(x)) > 3 }), "hello");
t_eq(filter("hi", fn (x) { len(chars(x)) > 3 }), nil);

// 测试 filter 对数组的操作
t_eq(filter([1, 2, 3, 4, 5], fn (x) { x % 2 == 0 }), [2, 4]);
t_eq(filter([1, 2, 3, 4, 5], fn (x, i) { i > 2 }), [4, 5]);
t_eq(filter([1, 2, 3], fn (x, i, data) { len(data) > 2 }), [1, 2, 3]);
t_eq(filter([], fn (x) { true }), []);

// 测试 filter 对记录的操作
t_eq(filter((a: 1, b: 2, c: 3, d: 4), fn (x) { x % 2 == 0 }), (b: 2, d: 4));
t_eq(filter((a: 1, b: 2, c: 3, d: nil), fn (x, k) { k != "b" }), (a: 1, c: 3, d: nil));
t_eq(filter((), fn (x) { true }), ());

// 测试 filter_map 函数

// 测试 filter_map 对基本类型的操作
t_eq(filter_map(42, fn (x) {
  if x > 40 { x * 2 } else { nil }
}), 84);
t_eq(filter_map(42, fn (x) {
  if x > 50 { x * 2 } else { nil }
}), nil);
t_eq(filter_map("hello", fn (x) {
  if len(chars(x)) > 3 { `$x!` } else { nil }
}), "hello!");

// 测试 filter_map 对数组的操作
t_eq(filter_map([1, 2, 3, 4, 5], fn (x) {
  if x % 2 == 0 { x * 2 } else { nil }
}), [4, 8]);
t_eq(filter_map([1, 2, 3, 4], fn (x, i) {
  if i > 1 { x + i } else { nil }
}), [5, 7]);
t_eq(filter_map([1, 2, 3], fn (x, i, data) {
  if len(data) > 2 { x } else { nil }
}), [1, 2, 3]);
t_eq(filter_map([], fn (x) { x }), []);

// 测试 filter_map 对记录的操作
t_eq(filter_map((a: 1, b: 2, c: 3, d: 4), fn (x) {
  if x % 2 == 0 { x * 2 } else { nil }
}), (b: 4, d: 8));
t_eq(filter_map((a: 1, b: 2, c: 3), fn (x, k) {
  if k != "b" { `$k=$x` } else { nil }
}), (a: "a=1", c: "c=3"));
t_eq(filter_map((), fn (x) { x }), ());

// 测试错误处理

// 测试不支持的数据类型
t_throws(fn () {
  map(t_eq, fn (x) { x });
});

// 测试不可调用的函数参数
t_throws(fn () {
  map([1, 2, 3], nil);
});
t_throws(fn () {
  map([1, 2, 3], 42);
});
t_throws(fn () {
  map([1, 2, 3], "not a function");
});
t_throws(fn () {
  map([1, 2, 3], []);
});
t_throws(fn () {
  map([1, 2, 3], ());
});

t_throws(fn () {
  filter([1, 2, 3], nil);
});
t_throws(fn () {
  filter([1, 2, 3], 42);
});
t_throws(fn () {
  filter([1, 2, 3], "not a function");
});

t_throws(fn () {
  filter_map([1, 2, 3], nil);
});
t_throws(fn () {
  filter_map([1, 2, 3], 42);
});
t_throws(fn () {
  filter_map([1, 2, 3], "not a function");
});

// 测试 nil 数据参数
t_throws(fn () {
  map(nil, nil);
});
t_throws(fn () {
  filter(nil, nil);
});
t_throws(fn () {
  filter_map(nil, nil);
});

// 测试布尔值转换
t_eq(filter([0, 1, 2, nan, "", "hello", nil, false, true], fn (x) { x }), [0, 1, 2, nan, "", "hello", true]);

// mapper 返回函数
t_eq(map(0, fn (x) {
  return fn { x };
}), nil);
t_eq(map([0], fn (x) {
  return fn { x };
}), [nil]);
t_eq(filter_map([0], fn (x) {
  return fn { x };
}), [nil]);
t_eq(filter_map((x: 1), fn (x) {
  return fn { x };
}), (x: nil));
