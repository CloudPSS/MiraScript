t_eq(()::with('a', 1, 'b', fn { }, 'c', 'c', 'c', 'C'), (a: 1, b: nil, c: 'C'));
t_throws(fn { ()::with('x') });
t_throws(fn { nil::with('x', 1) });
t_throws(fn { nil::with(1, 2) });
t_throws(fn { nil::with([1], 2) });
t_throws(fn { v_fn::with() });
t_throws(fn { 1::with() });
t_throws(fn { v_extern::with() });
t_eq([]::with(), []);
t_eq([]::with('2', 0), [nil, nil, 0]);
t_eq([]::with(['2'], 0), [nil, nil, 0]);
t_eq([]::with(['2'], 0, 4, 2), [nil, nil, 0, nil, 2]);
t_eq([1, 2, 3]::with('a', 'x', 'b', 'y'), [1, 2, 3]);
t_eq([1, 2, 3]::with(['a', 1], 'x'), [1, 2, 3]);
t_eq([1, 2, 3]::with(['1.3', 1], 'x'), [1, [nil, 'x'], 3]);
t_eq([1, (), 3]::with(['1.3', 1], 'x'), [1, (1: 'x'), 3]);
t_eq(()::with([], 1), ());
t_eq(()::with(nil, 1), ());
t_eq(()::with([nil], 1), ());
t_eq([]::with([], 1), []);
t_eq([]::with(nil, 1), []);
t_eq([]::with([nil], 1), []);
t_eq([]::with([2, 'a'], 1), [nil, nil, (a: 1)]);
t_eq([]::with([2, 'a', 1.2], 1), [nil, nil, (a: ('1.2': 1))]);
t_eq([]::with([2, 'a', 2], 1), [nil, nil, (a: [nil, nil, 1])]);
t_eq((x: 1, 1: [nil, nil, 3])::with([1, '1', 'y'], 4), (x: 1, 1: [nil, (y: 4), 3]));
t_eq((x: 1, 1: [nil, nil, 3])::with([2, '1', 'y'], 4), (x: 1, 1: [nil, nil, 3], 2: (1: (y: 4))));
t_eq(()::with(['a', 'b', 'c', 'd'], 1), (a: (b: (c: (d: 1)))));
t_eq([]::with([1, 2, 3, 4], 1), [nil, [nil, nil, [nil, nil, nil, [nil, nil, nil, nil, 1]]]]);

let obj = (x: 1);
t_eq(obj::with('x', 2), (x: 2));
t_eq(obj::with(['x', 'y'], 2), (x: (y: 2)));
t_eq(obj::with(['x', '1'], 2), (x: (1: 2)));
t_eq(obj::with(['x', 1], 2), (x: [nil, 2]));
t_eq(obj::with(['x', 1.2], 2), (x: ('1.2': 2)));
t_eq(obj::with('x.y.z', 2), (x: 1, 'x.y.z': 2));
t_eq(obj::with('x/y/z', 2), (x: 1, 'x/y/z': 2));
t_eq(obj::with('x\0y\0z', 2), (x: 1, 'x\0y\0z': 2));
t_eq(obj::with('y', 2), (x: 1, y: 2));
t_eq(obj, (x: 1)); // no modify
t_eq(obj::with(['z'], 3), (x: 1, z: 3));
t_eq(obj::with([1], 3), (x: 1, 1: 3));
t_eq(obj::with(['1'], 3), (x: 1, 1: 3));
t_eq(obj::with([1, 2], 3), (x: 1, 1: [nil, nil, 3]));
t_eq(obj::with([1, '2'], 3), (x: 1, 1: (2: 3)));
