t_eq(repeat(1, 2), [1, 1]);
t_eq(repeat(1, "2"), [1, 1]);
t_eq(repeat(nil, 2), [nil, nil]);
t_eq(repeat("a", 3), ["a", "a", "a"]);
t_eq(repeat((), 0), []);
t_eq(repeat((), -0.999), []);
t_throws(fn { repeat() });
t_throws(fn { repeat(()) });
t_throws(fn { repeat((), '') });
t_throws(fn { repeat((), 'nan') });
t_throws(fn { repeat(1, inf) });
t_throws(fn { repeat(1, 1e100) });
t_throws(fn { repeat(1, -1) });
