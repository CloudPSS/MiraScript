t_throws(fn { sort() });
t_throws(fn { sort(nil) });
t_throws(fn { sort(()) });
t_throws(fn { sort(1) });
t_throws(fn { sort("1") });
t_throws(fn { sort([], ()) });
t_throws(fn { sort(["1", 2], fn { nil }) });
t_eq(sort([]), []);

// sort numbers
t_eq(sort([3, 1, 2]), [1, 2, 3]);
t_eq(sort([1, 2, 3]), [1, 2, 3]);
t_eq(sort([nan, inf, -inf, 0, 1, -1]), [-inf, -1, nan, 0, 1, inf]);
t_eq(sort([inf, -inf, 0, 1, -1, nan]), [-inf, -1, 0, nan, 1, inf]);
t_eq(sort([0, 1, 11, 10]), [0, 1, 10, 11]);
t_eq(sort([0, 0]), [0, 0]);

// sort strings
t_eq(sort(["c", "a", "b"]), ["a", "b", "c"]);
t_eq(sort(["a", "b", "c"]), ["a", "b", "c"]);
t_eq(sort(["c", "C", "a", "A", "b", "B"]), ["A", "B", "C", "a", "b", "c"]);
t_eq(sort(["a", "A"]), ["A", "a"]);
t_eq(sort(["a", "a"]), ["a", "a"]);
t_eq(sort(["a", "A", "a", "A"]), ["A", "A", "a", "a"]);
t_eq(sort(["a", "aa", "ab", "b", "ba"]), ["a", "aa", "ab", "b", "ba"]);
t_eq(sort(["a", "ab", "aa", "b", "ba"]), ["a", "aa", "ab", "b", "ba"]);

// sort mixed
t_eq(sort([nil, 0]), [nil, 0]);
t_eq(sort([0, nil]), [0, nil]);
t_eq(sort([nil, '']), [nil, '']);
t_eq(sort(['', nil]), ['', nil]);
t_eq(sort([0, nil, 'x']), [0, nil, 'x']);

// sort custom compare
t_eq(sort([3, 1, 2], fn (a, b) { b - a }), [3, 2, 1]);
t_eq(
  sort(
    ["c", "a", "b"],
    fn (a, b, ..rest) {
      t_eq(rest, []); // no more arguments
      if a > b { -1 } else if a < b { 1 } else { 0 }
    },
  ),
  ["c", "b", "a"],
);
t_eq(sort(["c", "a", "b"], fn (a, b) {
  if a > b { -1 } else if a < b { true } else { false }
}), ["c", "b", "a"]);

let arr = [1, 3, 2];
t_eq(sort(arr, fn (a, b) { b - a }), [3, 2, 1]);
t_eq(arr, [1, 3, 2]); // no modify
