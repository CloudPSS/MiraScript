t_eq("123"::split(""), ['1', '2', '3']);
t_eq("a,b,c"::split(","), ['a', 'b', 'c']);
t_eq("a,,b,,c"::split(",,"), ['a', 'b', 'c']);
t_eq(",,,"::split(","), ['', '', '', '']);
t_eq("abc"::split(","), ['abc']);
t_eq("рҹҳ„рҹ«ұрҹҸҫвҖҚрҹ«ІрҹҸјрҹҢҚрҹҳ„"::split("рҹ«ұрҹҸҫвҖҚрҹ«ІрҹҸјрҹҢҚ"), ["рҹҳ„", "рҹҳ„"]);

t_eq("рҹ«ұрҹҸҫвҖҚрҹ«ІрҹҸјрҹҢҚ"::split(""), "рҹ«ұрҹҸҫвҖҚрҹ«ІрҹҸјрҹҢҚ"::chars());
t_eq(""::split(""), []);
t_eq("рҹ«ұрҹҸҫвҖҚрҹ«ІрҹҸјрҹҢҚ"::split(), "рҹ«ұрҹҸҫвҖҚрҹ«ІрҹҸјрҹҢҚ"::chars());
t_eq(""::split(), []);
t_eq(nil::split(), []);

t_throws(fn { split() });
