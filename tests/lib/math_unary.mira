let func = (:trunc, :floor, :ceil, :round, :sign, :abs, :acos, :acosh, :asin, :asinh, :atan, :atanh, :cos, :cosh, :sin, :sinh, :tan, :tanh, :exp, :expm1, :log, :log10, :log1p, :log2, :sqrt, :cbrt);

fn check_math_unary(fName, f, x, expected) {
  let actual = f(x);
  if expected is nan or +inf or -inf || global.trunc(expected) == expected {
    t_eq(actual, expected, `${ fName }(${ x }) should be ${ expected }, actual: ${ actual }`);
  } else {
    t_true(actual =~ expected, `${ fName }(${ x }) should be ${ expected }, actual: ${ actual }`);
  }
}

for (f, expected) in func::entries() {
  let fun = global[f];
  t_eq(type(fun), 'function');
  check_math_unary(f, fun, 0, expected.0);
  check_math_unary(f, fun, false, expected.0);
  check_math_unary(f, fun, nil, expected.0);
  check_math_unary(f, fun, -0, expected.1);
  check_math_unary(f, fun, 1, expected.2);
  check_math_unary(f, fun, true, expected.2);
  check_math_unary(f, fun, -1, expected.3);
  check_math_unary(f, fun, "-1 ", expected.3);
  check_math_unary(f, fun, nan, expected.4);
  check_math_unary(f, fun, "xx", expected.4);
  check_math_unary(f, fun, (1,), expected.4);
  check_math_unary(f, fun, [2], expected.4);
  check_math_unary(f, fun, inf, expected.5);
  check_math_unary(f, fun, "Infinity", expected.5);
  check_math_unary(f, fun, -inf, expected.6);
  check_math_unary(f, fun, "-inf", expected.6);
  check_math_unary(f, fun, @e, expected.7);
  check_math_unary(f, fun, -@e, expected.8);
  check_math_unary(f, fun, 1 / @e, expected.9);
  check_math_unary(f, fun, @e - 1, expected.10);
  check_math_unary(f, fun, @e + 1, expected.11);
  check_math_unary(f, fun, @pi, expected.12);
  check_math_unary(f, fun, -@pi, expected.13);
  check_math_unary(f, fun, @pi - 1, expected.14);
  check_math_unary(f, fun, @pi + 1, expected.15);
  check_math_unary(f, fun, @pi / 2, expected.16);
  check_math_unary(f, fun, @pi / 4, expected.17);
  check_math_unary(f, fun, 0.5, expected.18);
  check_math_unary(f, fun, 1.5, expected.19);
  check_math_unary(f, fun, -0.5, expected.20);
  t_throws(fn { fun() });
}