
let whitespaces = "\t\v\f \u{A0} \n\r\u{FEFF}\u{2028}\u{2029}";
t_eq("$(whitespaces)1$(whitespaces)"::trim(), "1");
t_eq("$(whitespaces)1$(whitespaces)"::trim_start(), "1$(whitespaces)");
t_eq("$(whitespaces)1$(whitespaces)"::trim_end(), "$(whitespaces)1");

t_true(whitespaces::starts_with("\t"));
t_true(whitespaces::ends_with("\u{2029}"));
t_true(whitespaces::contains("\n\r"));
t_false(whitespaces::contains("a"));
t_true("123"::starts_with(12));
t_true("123"::ends_with(23));
t_true("123"::contains(2));
t_true(123::contains(2));

t_throws(fn { contains() });
t_throws(fn { contains(1) });
t_throws(fn { starts_with() });
t_throws(fn { starts_with(1) });
t_throws(fn { ends_with() });
t_throws(fn { ends_with(1) });

t_eq("123"::chars()::len(), 3);
t_eq("é"::chars()::len(), 1);
t_eq("🫱🏾‍🫲🏼🌍"::chars()::len(), 6);

t_eq("Hello, World!"::replace("World", "Mira"), "Hello, Mira!");
t_eq("Hello, World! World!"::replace("World", "Mira"), "Hello, Mira! Mira!");
t_eq("xxx"::replace("xx", "y"), "yx");

t_eq("123"::split(""), ['1', '2', '3']);
t_eq("a,b,c"::split(","), ['a', 'b', 'c']);
t_eq("a,,b,,c"::split(",,"), ['a', 'b', 'c']);
t_eq(",,,"::split(","), ['', '', '', '']);
t_eq("abc"::split(","), ['abc']);
t_eq("😄🫱🏾‍🫲🏼🌍😄"::split("🫱🏾‍🫲🏼🌍"), ["😄", "😄"]);

t_eq("🫱🏾‍🫲🏼🌍"::split(""), "🫱🏾‍🫲🏼🌍"::chars());
t_eq(""::split(""), []);
