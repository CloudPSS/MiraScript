// math.ts 中的函数
// atan2
t_true(atan2(1, 1) =~ 0.785_398_163_397_448_3);
t_true(atan2(0, 1) == 0);
t_true(atan2(1, 0) =~ 1.570_796_326_794_896_6);
t_eq(atan2(true, nil), atan2(1, 0));
t_true(atan2(-1, -1) =~ -2.356_194_490_192_345);

// pow
t_eq(pow(nan, 0), 1);
t_eq(pow(inf, 0), 1);
t_eq(pow((-inf), 0), 1);
t_eq(pow(0, inf), 0);
t_eq(pow(2, inf), inf);
t_eq(pow(2, -inf), 0);
t_eq(pow(2, 3), 8);
t_eq(pow(4, 0.5), 2);
t_eq(pow(-2, 3), -8);

// random
t_eq(type(random()), 'number');
for i in 1..1000 {
  t_true(random() is 0..<1);
}