t_eq(1::type(), 'number');
t_eq(1.0::type(), 'number');
t_eq(nan::type(), 'number');
t_eq(true::type(), 'boolean');
t_eq(false::type(), 'boolean');
t_eq(nil::type(), 'nil');
t_eq(''::type(), 'string');
t_eq('abc'::type(), 'string');
t_eq(type(()), 'record');
t_eq(type([]), 'array');

// type as identifier name
{
  let type = 'type';
  t_eq(type::type(), 'string');
  t_eq(type, 'type');
}

// type as identifier name - destructuring assignment
{
  let (:type) = (type: 'type');
  t_eq(type::type(), 'string');
  t_eq(type, 'type');
}

// type as identifier name - omit name destructuring assignment
{
  let (type,) = ('type',);
  t_eq(type::type(), 'string');
  t_eq(type, 'type');
}

// type as identifier name - other use cases
{
  let type = ['type'];
  for i in type {
    t_eq(i::type(), 'string');
    t_eq(i, 'type');
  }
}
{
  let type = '123';
  t_eq(type::chars(), ['1', '2', '3']);
}
{
  let type = 5;
  let mut sum = 0;
  for i in 0..type {
    sum += i;
  }
  t_eq(sum, 15);
}
{
  let type = false;
  while type {
    t_never();
  }
}
{
  let type = true;
  if !type {
    t_never();
  }
}
{
  let type = 1;
  match type {
    case 1 { t_eq(type, 1) }
    case _ { t_never() }
  }
}