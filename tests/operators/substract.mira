t_eq(5 - 2, 3);
t_eq(0 - 0, 0);
t_eq(0 - -0, 0);
t_eq((-0) - 0, -0);
t_eq((-0) - -0, 0);
t_eq(inf - inf, nan);
t_eq((-inf) - (-inf), nan);
t_eq(inf - (-inf), inf);
t_eq((-inf) - inf, -inf);
t_eq(nan - 1, nan);
t_eq(nan - nan, nan);
t_eq(nan - inf, nan);
t_eq(inf - nan, nan);

t_throws(fn { ({ nil }) - 1 });
t_throws(fn { 1 - { 'NAN' } });
t_eq({ '12' } - { '3.5' }, 8.5);
t_eq({ false } - { true }, -1);
