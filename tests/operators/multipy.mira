t_eq(3 * 4, 12);
t_eq(0 * 0, 0);
t_eq(0 * -0, -0);
t_eq((-0) * 0, -0);
t_eq((-0) * -0, 0);
t_eq(inf * 2, inf);
t_eq(inf * -2, -inf);
t_eq((-inf) * 2, -inf);
t_eq((-inf) * -2, inf);
t_eq(inf * 0, nan);
t_eq(inf * -0, nan);
t_eq((-inf) * 0, nan);
t_eq((-inf) * -0, nan);
t_eq(nan * 1, nan);
t_eq(nan * inf, nan);
t_eq(inf * nan, nan);

t_eq(2 * 3, 6);
t_eq({ '4' } * { '5' }, 20);
t_eq({ true } * 10, 10);
t_eq({ false } * 10, 0);
t_eq({ false } * -10, -0);

t_throws(fn { ({ nil } * 1) });
t_throws(fn { 1 * { 'NAN' } });
