fn T { true }
fn F { false }
fn N { nil }
fn O { 0 }

t_true(T());
t_throws(fn { !!O() });
t_false(F());
t_throws(fn { !!N() });

t_eq(T() && T(), true);
t_throws(fn { T() && O() });
t_eq(T() && F(), false);
t_throws(fn { T() && N() });
t_throws(fn { O() && N() });
t_eq(F() && T(), false);
t_eq(F() && N(), false);
t_eq(F() && F(), false);
t_throws(fn { N() && T() });
t_throws(fn { N() && F() });
t_throws(fn { N() && N() });

// short-circuiting
t_eq(F() && t_never(), false);
t_eq(T() || t_never(), true);

t_eq(T() || T(), true);
t_eq(T() || O(), true);
t_eq(T() || F(), true);
t_throws(fn { O() || F() });
t_throws(fn { O() || N() });
t_eq(F() || T(), true);
t_throws(fn { F() || O() });
t_throws(fn { N() || O() });
t_eq(F() || F(), false);
t_eq(F() || F(), false);
t_throws(fn { N() || N() });
