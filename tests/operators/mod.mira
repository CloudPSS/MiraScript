t_eq(0 % 3, 0);
t_eq(0 % -3, 0);
t_eq((-0) % 3, -0);
t_eq((-0) % (-3), -0);

t_eq(0 % 0, nan);
t_eq(1 % 0, nan);
t_eq((-1) % 0, nan);
t_eq((-0) % 0, nan);

t_eq(0 % -0, nan);
t_eq(1 % -0, nan);
t_eq((-1) % -0, nan);
t_eq((-0) % -0, nan);

t_eq(7 % 3, 1);
t_eq((-7) % 3, -1);
t_eq((-7) % (-3), -1);
t_eq(7 % (-3), 1);

t_eq(8 % 3, 2);
t_eq((-8) % 3, -2);
t_eq((-8) % (-3), -2);
t_eq(8 % (-3), 2);

t_eq(9 % 3, 0);
t_eq((-9) % 3, -0);
t_eq((-9) % (-3), -0);
t_eq(9 % (-3), 0);

t_eq(5.5 % 2, 1.5);
t_eq((-5.5) % 2, -1.5);
t_eq((-5.5) % (-2), -1.5);
t_eq(5.5 % (-2), 1.5);

t_eq(12.25 % 0.5, 0.25);
t_eq((-12.25) % 0.5, -0.25);
t_eq((-12.25) % (-0.5), -0.25);
t_eq(12.25 % (-0.5), 0.25);

t_eq(inf % 3, nan);
t_eq((-inf) % 3, nan);
t_eq(inf % (-3), nan);
t_eq((-inf) % (-3), nan);

t_eq(3 % inf, 3);
t_eq((-3) % inf, -3);
t_eq(3 % (-inf), 3);
t_eq((-3) % (-inf), -3);

t_eq(nan % 1, nan);
t_eq(1 % nan, nan);
t_eq(nan % nan, nan);
t_eq(nan % inf, nan);
t_eq(inf % nan, nan);

t_throws(fn { nil % 1 });
t_throws(fn { 1 % 'NAN' });
