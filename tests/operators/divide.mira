t_eq(8 / 4, 2);
t_eq(0 / 1, 0);
t_eq(0 / -1, -0);
t_eq((-0) / 1, -0);
t_eq((-0) / -1, 0);
t_eq(1 / 0, inf);
t_eq(1 / -0, -inf);
t_eq(-1 / 0, -inf);
t_eq(-1 / -0, inf);
t_eq(inf / 2, inf);
t_eq(inf / -2, -inf);
t_eq((-inf) / 2, -inf);
t_eq((-inf) / -2, inf);
t_eq(2 / inf, 0);
t_eq(2 / -inf, -0);
t_eq((-2) / inf, -0);
t_eq((-2) / -inf, 0);
t_eq(inf / inf, nan);
t_eq(inf / -inf, nan);
t_eq((-inf) / inf, nan);
t_eq((-inf) / -inf, nan);
t_eq(0 / 0, nan);
t_eq((-0) / 0, nan);
t_eq(0 / -0, nan);
t_eq((-0) / -0, nan);
t_eq(nan / 1, nan);

t_eq(6 / 2, 3);
t_eq('8' / '4', 2);
t_eq(true / 2, 0.5);
t_eq(false / 10, 0);
t_eq(false / -10, -0);

t_throws(fn { nil / 1 });
t_throws(fn { 1 / 'NAN' });
