t_eq(2^3, 8);
t_eq(2^(-3), 0.125);
t_eq(2^0, 1);
t_eq(2^-0, 1);
t_eq(0^0, 1);
t_eq(0^-0, 1);
t_eq(nan^0, 1);
t_eq(inf^0, 1);
t_eq((-inf)^0, 1);
t_eq((-1)^0.5, nan);
t_eq(0^inf, 0);
t_eq((-0)^inf, 0);
t_eq(2^inf, inf);
t_eq(2^(-inf), 0);
t_eq(2^nan, nan);
t_eq(nan^2, nan);
t_eq(inf^2, inf);
t_eq(inf^-2, 0);
t_eq((-inf)^-2, 0);
t_eq((-inf)^3, -inf);
t_eq((-inf)^-3, -0);

t_eq(-1^2, -1);
t_eq(-(1^2), -1);
t_eq((-1)^2, 1);

t_eq(2^3^2, 512);
t_eq((2^3)^2, 64);
t_eq(2^2^2^2, 65536);
t_eq((2^2)^(2^2), 256);

t_throws(fn { ({ nil })^1 });
t_throws(fn { 1^{ 'NAN' } });
