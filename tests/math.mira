// math.ts 中的函数
// atan2
t_snapshot(atan2(1, 1));
t_snapshot(atan2(0, 1));
t_snapshot(atan2(1, 0));
t_snapshot(atan2(-1, -1));

// pow
t_eq(pow(nan, 0), 1);
t_eq(pow(inf, 0), 1);
t_eq(pow((-inf), 0), 1);
t_eq(pow(0, inf), 0);
t_eq(pow(2, inf), inf);
t_eq(pow(2, -inf), 0);
t_eq(pow(2, 3), 8);
t_eq(pow(4, 0.5), 2);
t_eq(pow(-2, 3), -8);

// random
t_eq(type(random()), 'number');
t_true(random() is 0..<1);

// math-arr.ts 中的函数
// max
t_eq(max(1, 2, 3), 3);
t_eq(max([1, 2, 3]), 3);
t_eq(max(-1, -2, -3), -1);
t_eq(max(), -inf);

// min
t_eq(min(1, 2, 3), 1);
t_eq(min([1, 2, 3]), 1);
t_eq(min(-1, -2, -3), -3);
t_eq(min(), inf);

// hypot
t_eq(hypot(3, 4), 5);
t_eq(hypot(5, 12), 13);
t_snapshot(hypot(1, 1));
t_eq(hypot([3, 4]), 5);

// math-unary.ts 中的函数
// trunc
t_eq(trunc(13.37), 13);
t_eq(trunc(42.84), 42);
t_eq(trunc(-0.123), -0);
t_eq(trunc(-13.37), -13);

// floor
t_eq(floor(13.37), 13);
t_eq(floor(42.84), 42);
t_eq(floor(-0.123), -1);
t_eq(floor(-13.37), -14);

// ceil
t_eq(ceil(1.5), 2);
t_eq(ceil(-1.5), -1);
t_eq(ceil(13.37), 14);
t_eq(ceil(-13.37), -13);

// round
t_eq(round(13.37), 13);
t_eq(round(13.5), 14);
t_eq(round(-13.5), -13);
t_eq(round(-13.37), -13);

// sign
t_eq(sign(3), 1);
t_eq(sign(-3), -1);
t_eq(sign(0), 0);
t_eq(sign(-0), -0);

// abs
t_eq(abs(0), 0);
t_eq(abs(-0), 0);
t_eq(abs(1), 1);
t_eq(abs(-1), 1);
t_eq(abs(inf), inf);
t_eq(abs(-inf), inf);

// acos
t_snapshot(acos(0.5));
t_snapshot(acos(1));
t_snapshot(acos(-1));
t_snapshot(acos(0));

// acosh
t_snapshot(acosh(1.5));
t_snapshot(acosh(1));
t_snapshot(acosh(2));

// asin
t_snapshot(asin(0.5));
t_snapshot(asin(1));
t_snapshot(asin(-1));
t_snapshot(asin(0));

// asinh
t_snapshot(asinh(0.5));
t_snapshot(asinh(1));
t_snapshot(asinh(-1));
t_snapshot(asinh(0));

// atan
t_snapshot(atan(0.5));
t_snapshot(atan(1));
t_snapshot(atan(-1));
t_snapshot(atan(0));

// atanh
t_snapshot(atanh(0.5));
t_snapshot(atanh(0));
t_snapshot(atanh(-0.5));

// cos
t_eq(cos(0), 1);
t_snapshot(cos(@pi / 2));
t_snapshot(cos(@pi));
t_snapshot(cos(@pi * 2));

// cosh
t_snapshot(cosh(0));
t_snapshot(cosh(1));
t_snapshot(cosh(-1));

// sin
t_eq(sin(0), 0);
t_snapshot(sin(@pi / 2));
t_snapshot(sin(@pi));
t_snapshot(sin(@pi * 2));

// sinh
t_snapshot(sinh(0));
t_snapshot(sinh(1));
t_snapshot(sinh(-1));

// tan
t_eq(tan(0), 0);
t_snapshot(tan(@pi / 4));
t_snapshot(tan(@pi / 2));

// tanh
t_snapshot(tanh(0));
t_snapshot(tanh(1));
t_snapshot(tanh(-1));

// exp
t_snapshot(exp(0));
t_snapshot(exp(1));
t_snapshot(exp(-1));
t_snapshot(exp(2));

// expm1
t_snapshot(expm1(0));
t_snapshot(expm1(1));
t_snapshot(expm1(-1));

// log
t_snapshot(log(@e));
t_snapshot(log(1));
t_snapshot(log(10));

// log10
t_snapshot(log10(1));
t_snapshot(log10(10));
t_snapshot(log10(100));

// log1p
t_snapshot(log1p(0));
t_snapshot(log1p(@e - 1));
t_snapshot(log1p(9));

// log2
t_snapshot(log2(1));
t_snapshot(log2(2));
t_snapshot(log2(8));

// sqrt
t_eq(sqrt(4), 2);
t_eq(sqrt(9), 3);
t_eq(sqrt(0), 0);
t_snapshot(sqrt(2));

// cbrt
t_eq(cbrt(8), 2);
t_eq(cbrt(-8), -2);
t_eq(cbrt(0), 0);
t_snapshot(cbrt(2));
