t.eq(nil::type(), "nil");

t.eq(true::type(), "boolean");
t.eq(false::type(), "boolean");

t.eq(1::type(), "number");
t.eq(1.0::type(), "number");
t.eq(nan::type(), "number");
t.eq(inf::type(), "number");
t.eq((-inf)::type(), "number");

t.eq("Hello, World!"::type(), "string");
t.eq("é"::type(), "string");

t.eq(()::type(), "record");
t.eq((1,)::type(), "record");
t.eq((1, 2, 3)::type(), "record");
t.eq((a: 1, b: 2)::type(), "record");

t.eq([]::type(), "array");
t.eq([1, 2, 3]::type(), "array");
