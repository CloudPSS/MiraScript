// 测试 nil 及运算符本身
t.true(nil == nil);
t.false(nil != nil);
t.true(nil ~= nil);
t.false(nil ~! nil);

// boolean
t.true(true == true);
t.true(false == false);
t.false(true == false);
t.true(true ~= true);
t.false(false ~= true);

// number
t.true(1 == 1);
t.true(1 ~= 1);
t.true(1.0 == 1);
t.true(1.0 ~= 1);
t.false(0.1 + 0.2 == 0.3);
t.true(0.1 + 0.2 ~= 0.3);
t.false(1 == 2);
t.false(1 ~= 2);
t.false(nan == nan);
t.false(nan ~= nan);
t.true(inf == inf);
t.true(inf ~= inf);
t.true(-inf == -inf);
t.true(-inf ~= -inf);
t.true(+0 == -0);
t.true(+0 ~= -0);
t.true(1 ~! nan);
t.true(1 != nan);

// string
t.true('abc' == 'abc');
t.true('abc' ~= 'abc');
t.false('abc' == 'ABC');
t.true('abc' ~= 'ABC');
t.false('e' == 'é');
t.true('e' ~= 'é');
t.false('abc' == 'ab');
t.false('abc' ~= 'ab');

// aeq should convert to number or string
t.false(1 == '1');
t.true(1 ~= '1');
t.true(1 ~= '1.0');
t.true('1' ~= 1);
t.true('1.0' ~= 1);
t.true(true ~= 'true');
t.true('true' ~= true);
t.false('1' ~= true);
t.true(1 ~= true);
t.true(true ~= 1);
t.true(0 ~= false);
t.true(false ~= 0);
t.true('' ~= nil);
t.true(nil ~= '');
t.false('' ~= '0');

// complex
t.true((1, 2, 3) == (1, 2, 3));
t.true([1, 2, 3, nil, "xx", ("a", [true])] == [1, 2, 3, nil, "xx", ("a", [true])]);
t.false((1, 2, 3) ~= (1, 2, 3));

t.true([1, 2, 3] == [1, 2, 3]);
t.false([1, 2, 3] ~= [1, 2, 3]);

t.false([1, 2] == (1, 2));
t.false((1, 2, 3) == (1, 2, 4));
t.false([1, 2, 3] == [1, 2, 4]);
t.true((nan,) == (nan,));
t.false([nil] == []);
t.false((nil, nil) == (a: nil, b: nil));
t.false((a: nil) == ());
t.true((a?: nil) == ());
t.true((1, 2) == (1: 2, 0: 1));
t.true((1, 2) == ("1": 2, "0": 1));
