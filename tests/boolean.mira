t.snapshot(true);
t.snapshot(false);

t.eq(!false, true);
t.eq(!true, false);

t.eq(!!nil, false);
t.eq(!!nan, true);
t.eq(!!0, true);
t.eq(!!-0, true);
t.eq(!!1, true);
t.eq(!!"", true);

t.eq(to_boolean(nil), false);
t.eq(to_boolean(nan), true);
t.eq(to_boolean(0), true);
t.eq(to_boolean(-0), true);
t.eq(to_boolean(1), true);
t.eq(to_boolean(""), true);