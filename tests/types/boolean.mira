t_true(true);
t_false(false);

t_eq(!false, true);
t_eq(!true, false);

t_throws(fn { !!{ nil } });
t_throws(fn { !!{ nan } });
t_throws(fn { !!{ 0 } });
t_throws(fn { !!{ -0 } });
t_throws(fn { !!{ 1 } });
t_throws(fn { !!{ inf } });
t_throws(fn { !!{ "" } });
t_throws(fn { !!{ "true" } });
t_throws(fn { !!{ "false" } });
t_throws(fn { !!{ "0" } });
t_throws(fn { !!{ "1" } });

t_false(false in true);
t_false(false in false);

t_throws(fn {
  let b = true;
  b.f = 1;
});

{
  let b = true;
  t_eq(b, true);
  t_eq(b.x, nil);
  t_eq(b['x'], nil);
  t_eq(b[0], nil);
  t_eq(b[true], nil);
  t_eq(b[false], nil);
}