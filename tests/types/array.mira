t_eq([1..5], [1, 2, 3, 4, 5]);
t_eq([1..<5], [1, 2, 3, 4]);
t_eq([1..5.5], [1, 2, 3, 4, 5]);
t_eq([1..<5.5], [1, 2, 3, 4, 5]);
t_eq([0.2..2.2], [0.2, 1.2, 2.2]);
t_eq([0.2..<2.2], [0.2, 1.2]);
t_eq(["0.2"..<"2.2"], [0.2, 1.2]);
t_throws(fn { [""..1] });
t_throws(fn { [1..""] });
t_eq([1..1], [1]);
t_eq([1..<1], []);
t_eq([1..0], []);

t_eq([0..inf], []);
t_eq([nan..nan], []);
t_eq([0..<inf], []);
t_eq([nan..<nan], []);

t_eq([1..1000].166, 167);
t_eq([1..1000][166], 167);
t_eq([1..1000][-166], 835);
t_eq([1..1000].255, 256);
t_eq([1..1000].256, 257);
t_eq([1..1000].999, 1000);
t_eq([1..1000].1000, nil);
t_eq([1..1000].1001, nil);
t_eq([1..1000][-255], 746);
t_eq([1..1000][-256], 745);
t_eq([1..1000][-999], 2);
t_eq([1..1000][-1000], 1);
t_eq([1..1000][-1001], nil);

t_eq([1, 2, 3..5, ..[6, 7], ..nil], [1, 2, 3, 4, 5, 6, 7]);
t_throws(fn { [..1] });
t_throws(fn { [.."x"] });
t_throws(fn { [..true] });
t_throws(fn { [..()] });
t_throws(fn { [..v_module] });
if has_extern {
  t_throws(fn { [..v_extern] });
}

let arr = [0, 1, nan, (0, -0), (1, 2, 3)];
t_true(0 in arr);
t_true((-0) in arr);
t_true((-0, 0) in arr);
t_true((0, 0) in arr);
t_true(1 in arr);
t_true(nan in arr);
t_true((1, 2, 3) in arr);
t_false(2 in arr);
t_false(nil in arr);
t_true(nil in [nil]);
t_eq(arr[0], 0);
t_eq(arr[-0], 0);
t_eq(arr[0.999_999_999], 0);
t_eq(arr[-0.999_999_999], 0);
t_eq(arr[1], 1);
t_eq(arr[1.999_999_999], 1);
t_eq(arr[2], nan);
t_eq(arr[3], (0, -0));
t_eq(arr[4], (1, 2, 3));
t_eq(arr[-1], (1, 2, 3));
t_eq(arr[-1.999_999_999], (1, 2, 3));
t_eq(arr[-2], (0, -0));
t_eq(arr[-3], nan);
t_eq(arr[-4], 1);
t_eq(arr[-5], 0);

t_eq(arr[true], 1);
t_eq(arr[false], 0);

t_eq(arr[-6], nil);
t_eq(arr[5], nil);
t_eq(arr[500], nil);
t_eq(arr[nan], nil);
t_eq(arr[inf], nil);
t_eq(arr.xxx, nil);

t_throws(fn {
  let a = [];
  a[0] = 1;
});
