t_eq((), ());
t_eq((1,), (0: 1));
t_eq((1, 2), (0: 1, 1: 2));
t_eq((1, 2, ..(3, 4)), (0: 3, 1: 4));

t_eq((a: fn { }), (a: nil));
t_eq((a?: fn { }), ());
t_eq((a?: 1, b?: nil), (a: 1));

t_eq((..(a: 1), a: 2), (a: 2));
t_eq((..(a: 1), a: nil), (a: nil));
t_eq((..(a: 1), a?: nil), (a: 1));

let (x, y) = (1, 2);
t_eq(("$x": 1, "$y": 2, "$x$y"?: 3, "$y$x"?: nil), (1: 1, 2: 2, '12': 3));

t_eq((0?: nil, 1?: 1), (1: 1));

{
  let obj = (
    a: 1,
    b: 2,
    c: nil,
    '': 'empty key',
    true: 'tv',
    false: v_false,
    1: 'one',
    '-1': 'minus one',
    '0': 'zero',
  );
  t_eq(obj.a, 1);
  t_eq(obj.b, 2);
  t_eq(obj['a'], 1);
  t_eq(obj['b'], 2);
  t_eq(obj['c'], nil);
  t_eq(obj.c, nil);
  t_true('c' in obj);
  t_false('d' in obj);
  t_true(`${ nil }${ 'c' }` in obj);
  t_true('' in obj);
  t_true(nil in obj); // to_string(nil) is ''
  t_true(true in obj);
  t_true('true' in obj);
  t_true(false in obj);
  t_true('false' in obj);
  t_true(1 in obj);
  t_false(2 in obj);
  t_true(-1 in obj);
  t_true((1.0 * -1) in obj);
  t_true('-1' in obj);
  t_true(0 in obj);
  t_true('0' in obj);
  t_true(-0 in obj);
  t_false('-0' in obj);

  t_true('a' in obj);
  t_false('a' in nil);

  t_eq(obj[''], 'empty key');
  t_eq(obj[nil], 'empty key');
  t_eq(obj[true], 'tv');
  t_eq(obj['true'], 'tv');
  t_eq(obj[false], v_false);
  t_eq(obj['false'], v_false);
  t_eq(obj[1], 'one');
  t_eq(obj.1, 'one');
  t_eq(obj['1'], 'one');
  t_eq(obj[-1], 'minus one');
  t_eq(obj['-1'], 'minus one');
  t_eq(obj[0], 'zero');
  t_eq(obj['0'], 'zero');
  t_eq(obj[-0], 'zero');
}

{
  let obj = ('x', 'y', nil);
  t_true(0 in obj);
  t_true([0] in obj);
  t_true('0' in obj);
  t_true(00 in obj);
  t_false('00' in obj);

  t_true(2 in obj);
  t_true([2] in obj);
  t_false(nil in obj);
  t_false(3 in obj);
}

{
  let mut obj = (0, 'str', true, nil, (a: 1, b: 2), [1, 2, 3], v_fn);
  t_eq(obj.0, 0);
  t_eq(obj.1, 'str');
  t_eq(obj.2, true);
  t_eq(obj.3, nil);
  t_eq(obj.4.a, 1);
  t_eq(obj.4.b, 2);
  t_eq(obj.5.0, 1);
  t_eq(obj.5.1, 2);
  t_eq(obj.5.2, 3);
  t_eq(obj.5::len(), 3);
  t_eq(obj.6, nil);

  t_true(3 in obj);
  t_true(6 in obj);
  t_false(7 in obj);

  obj = (0?: 0, 1?: 'str', 2?: true, 3?: nil, 4?: (a: 1, b: 2), 5?: [1, 2, 3], 6?: v_fn);
  t_eq(obj.0, 0);
  t_eq(obj.1, 'str');
  t_eq(obj.2, true);
  t_eq(obj.3, nil);
  t_eq(obj.4.a, 1);
  t_eq(obj.4.b, 2);
  t_eq(obj.5.0, 1);
  t_eq(obj.5.1, 2);
  t_eq(obj.5.2, 3);
  t_eq(obj.5::len(), 3);
  t_eq(obj.6, nil);

  t_false(3 in obj);
  t_false(6 in obj);
}

t_throws(fn {
  let r = (x: 1);
  r.x = 2;
});

{
  let special = ['"', "'"];
  let obj = ('", \'': 1, '"': 2, "'": 3, '", \'': 4, '\r\n': 'crlf', '\n': 'lf');
  t_eq(obj[special], 4);
  t_eq(obj[special.0], 2);
  t_eq(obj[special.1], 3);
  t_eq(obj['
'], 'lf');
  t_eq(obj['\r\n'], 'crlf');
}

{
  let r = (a: 1, b: 2);
  t_true('a' in r);
  t_true('b' in r);
  t_false('c' in r);
  let (a, b, c) = ('a', 'b', 'c');
  t_true(a in r);
  t_true(b in r);
  t_false(c in r);
}