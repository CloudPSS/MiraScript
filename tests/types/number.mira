t_eq(0e0, 0);
t_eq(1.1e1, 11);
t_eq(-1.1e1, -11);
t_eq(1.1e-1, 0.11);
t_eq(-1.1e-1, -0.11);
t_eq(12.34e+56, 1_234_000_000_000_000_000_000_000_000_000_000_000_000_000_000_000_000_000_000);
t_eq(0xAB_CDEF, 11259375);
t_eq(0xFFAB_CDEF, 4_289_449_455);
t_eq(0o123456, 42798);
t_eq(0b10101010, 170);

let zero = 1 - 1;
let n_zero = -zero;
t_ne(zero, n_zero);
t_ne([zero], [n_zero]);
t_eq(-1 * zero, n_zero);
t_eq(zero / zero, nan);
t_eq((zero / zero, '' / false), (nan, nan));
t_eq(zero - zero, zero);
t_eq(zero + zero, zero);
t_eq(n_zero - n_zero, zero);
t_eq(n_zero + n_zero, n_zero);
t_eq(1 / zero, inf);
t_eq(-1 / zero, -inf);
t_eq(1e200 / 1e-200, inf);
t_eq(-1e200 / 1e-200, -inf);
t_eq(inf + inf, inf);
t_eq(-inf + -inf, -inf);
t_eq(inf - inf, nan);
t_eq(-inf - -inf, nan);
t_eq(inf * 0, nan);
t_eq(-inf * 0, nan);
t_eq(inf / inf, nan);
t_eq(-inf / -inf, nan);
t_eq(inf / -inf, nan);
t_eq(-inf / inf, nan);

t_true(nan != nan);
t_false(nan =~ nan);
t_true(nan is nan);

t_false(0 in 0);
t_false(nan in 0);
t_false(nan in nan);
