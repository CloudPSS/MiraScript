t_eq(nil, nil);

let n = nil;

t_throws(fn {
  n.f = 1;
});
t_eq(n.f, nil);

t_throws(fn {
  n[0] = 1;
});
t_eq(n[0], nil);

t_throws(fn {
  n[`${ 'x' }`] = 1;
});
t_eq(n[`${ 'x' }`], nil);

t_false('x' in n);
t_false(nil in n);
t_false(() in n);

{
  let n = nil;
  t_eq(n, nil);
  t_eq(n.x, nil);
  t_eq(n['x'], nil);
  t_eq(n[0], nil);
  t_eq(n[true], nil);
  t_eq(n[false], nil);
}