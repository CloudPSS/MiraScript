t_eq(nan, nan);
t_ne(+0, -0);
t_eq(+0, 0);
t_ne(-0, 0);

t_eq(2 + 2, 4);
t_eq('   1' + '2  ', 3);
t_eq('1' + '', 1);
t_eq('Hello, ' + 'World!', nan);
t_eq([1] + 2, nan);

t_eq(2 - 1, 1);
t_eq(true - false, 1);
t_eq(nil - '\n', 0);

t_eq(+nil, 0);
t_eq(+true, 1);
t_eq(+false, 0);
t_eq(+'12', 12);
t_eq(+[1], nan);

t_eq(-nil, -0);
t_eq(-true, -1);
t_eq(-false, -0);
t_eq(-'12.7', -12.7);
t_eq(-(1,), nan);

t_eq(nil + true, 1);
t_eq(nil + false, 0);
t_eq('12' + '3.5', 15.5);

t_eq(nil - true, -1);
t_eq(nil - false, 0);
t_eq('12' - '3.5', 8.5);

t_eq(2 * 3, 6);
t_eq('4' * '5', 20);
t_eq(true * 10, 10);
t_eq(false * 10, 0);
t_eq(false * -10, -0);

t_eq(6 / 2, 3);
t_eq('8' / '4', 2);
t_eq(true / 2, 0.5);
t_eq(false / 10, 0);
t_eq(false / -10, -0);

t_eq(1 + 2, 3);
t_eq(0 + 0, 0);
t_eq(0 + -0, 0);
t_eq((-0) + -0, -0);
t_eq((-0) + 0, 0);
t_eq(inf + inf, inf);
t_eq((-inf) + (-inf), -inf);
t_eq(inf + (-inf), nan);
t_eq(nan + 1, nan);

t_eq(5 - 2, 3);
t_eq(0 - 0, 0);
t_eq(0 - -0, 0);
t_eq((-0) - 0, -0);
t_eq((-0) - -0, 0);
t_eq(inf - inf, nan);
t_eq((-inf) - (-inf), nan);
t_eq(inf - (-inf), inf);
t_eq((-inf) - inf, -inf);
t_eq(nan - 1, nan);

t_eq(3 * 4, 12);
t_eq(0 * 0, 0);
t_eq(0 * -0, -0);
t_eq((-0) * 0, -0);
t_eq((-0) * -0, 0);
t_eq(inf * 2, inf);
t_eq(inf * -2, -inf);
t_eq((-inf) * 2, -inf);
t_eq((-inf) * -2, inf);
t_eq(inf * 0, nan);
t_eq(inf * -0, nan);
t_eq((-inf) * 0, nan);
t_eq((-inf) * -0, nan);
t_eq(nan * 1, nan);

t_eq(8 / 4, 2);
t_eq(0 / 1, 0);
t_eq(0 / -1, -0);
t_eq((-0) / 1, -0);
t_eq((-0) / -1, 0);
t_eq(1 / 0, inf);
t_eq(1 / -0, -inf);
t_eq(-1 / 0, -inf);
t_eq(-1 / -0, inf);
t_eq(0 / 0, nan);
t_eq((-0) / 0, nan);
t_eq(0 / -0, nan);
t_eq((-0) / -0, nan);
t_eq(nan / 1, nan);

// 取余的行为比较复杂，多加一些测试用例
t_eq(0 % 3, 0);
t_eq(0 % -3, 0);
t_eq((-0) % 3, -0);
t_eq((-0) % (-3), -0);

t_eq(0 % 0, nan);
t_eq(1 % 0, nan);
t_eq((-1) % 0, nan);
t_eq((-0) % 0, nan);

t_eq(0 % -0, nan);
t_eq(1 % -0, nan);
t_eq((-1) % -0, nan);
t_eq((-0) % -0, nan);

t_eq(7 % 3, 1);
t_eq((-7) % 3, -1);
t_eq((-7) % (-3), -1);
t_eq(7 % (-3), 1);

t_eq(8 % 3, 2);
t_eq((-8) % 3, -2);
t_eq((-8) % (-3), -2);
t_eq(8 % (-3), 2);

t_eq(9 % 3, 0);
t_eq((-9) % 3, -0);
t_eq((-9) % (-3), -0);
t_eq(9 % (-3), 0);

t_eq(5.5 % 2, 1.5);
t_eq((-5.5) % 2, -1.5);
t_eq((-5.5) % (-2), -1.5);
t_eq(5.5 % (-2), 1.5);

t_eq(12.25 % 0.5, 0.25);
t_eq((-12.25) % 0.5, -0.25);
t_eq((-12.25) % (-0.5), -0.25);
t_eq(12.25 % (-0.5), 0.25);

t_eq(+(-3), -3);
t_eq(+(+3), 3);

t_eq(12 * 7 + 6^2 / 2 - 4 % 3, 101);
t_eq(12 * (7 + 6^2) / (2 - 4) % 3, -0);

t_eq(-1^2, -1);
t_eq(-(1^2), -1);
t_eq((-1)^2, 1);

t_eq(2^3^2, 512);
t_eq((2^3)^2, 64);
t_eq(2^2^2^2, 65536);
t_eq((2^2)^(2^2), 256);

t_eq(2^3, 8);
t_eq(2^(-3), 0.125);
t_eq(2^0, 1);
t_eq(2^-0, 1);
t_eq(0^0, 1);
t_eq(0^-0, 1);
t_eq(nan^0, 1);
t_eq(inf^0, 1);
t_eq((-inf)^0, 1);
t_eq((-1)^0.5, nan);
t_eq(0^inf, 0);
t_eq((-0)^inf, 0);
t_eq(2^inf, inf);
t_eq(2^(-inf), 0);
