t_eq(nan, nan);
t_ne(+0, -0);
t_eq(+0, 0);
t_ne(-0, 0);

t_eq(2 + 2, 4);
t_eq('   1' + '2  ', 3);
t_eq('1' + '', 1);
t_eq('Hello, ' + 'World!', nan);
t_eq([1] + 2, nan);

t_eq(2 - 1, 1);
t_eq(true - false, 1);
t_eq(nil - '\n', 0);

t_eq(+nil, 0);
t_eq(+true, 1);
t_eq(+false, 0);
t_eq(+'12', 12);
t_eq(+[1], nan);

t_eq(-nil, -0);
t_eq(-true, -1);
t_eq(-false, -0);
t_eq(-'12.7', -12.7);
t_eq(-(1,), nan);

t_eq(+(-3), -3);
t_eq(+(+3), 3);

t_eq(12 * 7 + 6^2 / 2 - 4 % 3, 101);
t_eq(12 * (7 + 6^2) / (2 - 4) % 3, -0);
