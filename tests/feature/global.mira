 
t_true('v_nil' in global);
t_true('v_true' in global);
t_true('v_false' in global);

t_true(['v_nil'] in global);
t_true(['v_true'] in global);
t_true(['v_false'] in global);

t_eq(global[['v_nil']], nil);
t_eq(global[['v_true']], true);
t_eq(global[['v_false']], false);

t_eq(global.v_nil, nil);
t_eq(global.v_true, true);
t_eq(global.v_false, false);
