let arr1 = [1, 2, 3];
let arr2 = ['x', 'y'];

t_eq([..arr1, ..arr2], [1, 2, 3, 'x', 'y']);
t_eq([..arr2, ..arr1], ['x', 'y', 1, 2, 3]);
t_eq([0, ..arr1, 4], [0, 1, 2, 3, 4]);
t_eq([..nil], []);
t_eq([..nil, 1], [1]);
t_eq((..arr1), (1, 2, 3));
t_eq((..arr2), ('x', 'y'));
t_eq((0, ..arr1, 4), (1, 2, 4));
t_eq((..arr1, ..arr2), ('x', 'y', 3));
t_eq((..arr2, ..arr1), (1, 2, 3));

let obj1 = (1, 2, 3);
let obj2 = (x: 'a', y: 'b', z: 'c');
t_eq((..obj1, ..obj2), (x: 'a', y: 'b', z: 'c', 0: 1, 1: 2, 2: 3));
t_eq((..obj1, 'y'), (1, 'y', 3));
t_eq((..obj2, 'y'), (1: 'y', x: 'a', y: 'b', z: 'c'));
t_eq((..nil), ());
t_eq((..nil, 1), (1: 1));

t_throws(fn () {
  (..1);
});
t_throws(fn () {
  (..'x');
});
t_throws(fn () {
  (..true);
});
t_throws(fn () {
  [..1];
});
t_throws(fn () {
  [..'x'];
});
t_throws(fn () {
  [..true];
});
t_throws(fn () {
  [..()];
});

if has_extern {
  t_eq((..v_extern), ());
  t_throws(fn () { [..v_extern] });
}

if has_module {
  t_throws(fn () { (..v_module) });
  t_throws(fn () { [..v_module] });
}