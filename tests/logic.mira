fn T { true }
fn F { false }

t_true(T());
t_false(F());

t_true(T() && T());
t_false(T() && F());
t_false(F() && T());
t_false(F() && F());
t_false(F() && t_never()); // short-circuiting

t_true(T() || T());
t_true(T() || F());
t_true(F() || T());
t_false(F() || F());
t_true(T() || t_never()); // short-circuiting
