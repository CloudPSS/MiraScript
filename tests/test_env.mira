// 检查测试环境
fn assert_fn(value) {
  let vt = type(value);
  if vt != "function" {
    // 在完成检查前，使用该方式抛出异常
    nil!;
  }
}

assert_fn(t_eq);
assert_fn(t_ne);
assert_fn(t_true);
assert_fn(t_false);
assert_fn(t_throws);
assert_fn(t_never);

t_throws(fn {
  // 测试抛出异常
  nil!;
});

t_eq(type(v_array), 'array');
t_eq(v_array, []);
t_eq(type(v_record), 'record');
t_eq(v_record, ());
t_eq(v_nil, nil);
t_eq(v_true, true);
t_eq(v_false, false);
t_eq(v_number, 42);
t_eq(v_string, 'Hello, Mira!');
t_eq(v_fn::type(), 'function');
t_eq(v_fn_another::type(), 'function');
t_eq(v_fn(), 'I am a function');
t_eq(v_fn_another(), 'I am another function');
t_eq(v_module::type(), 'module');
t_eq(v_module_another::type(), 'module');
if has_extern {
  t_eq(v_extern::type(), 'extern');
  t_eq(v_extern_another::type(), 'extern');
} else {
  t_throws(fn { v_extern });
  t_throws(fn { v_extern_another });
}

t_true('v_nil' in global);
t_false('v_whatever' in global);

// 全局对象不应该有这些属性
// JS 常见的属性，但在 MiraScript 中不应该存在
t_false('__proto__' in global);
t_false('constructor' in global);
t_false('toString' in global);
// Python 常见的属性，但在 MiraScript 中不应该存在
t_false('ToString' in global);
t_false('with_' in global);
t_false('Call_' in global);
t_false('max_' in global);
t_false('__dict__' in global);
t_false('__class__' in global);
t_false('compile' in global);

if has_extern {
  t_true(v_extern == v_extern);
  t_false(v_extern == v_extern_another);
  t_eq(global['v_ext$('ern')'], v_extern);

  t_false('__proto__' in v_extern);
  t_false('constructor' in v_extern);
  t_false('toString' in v_extern);
  t_false('push' in v_extern);
  t_false('whatever' in v_extern);
  t_eq(v_extern['whatever'], nil);
}

t_false(v_module == v_module_another);
t_false('whatever' in v_module);
t_eq(v_module['whatever'], nil);

t_false(v_fn == v_fn_another);
if has_extern {
  t_false(v_extern == v_module);
}