{
  "name": "@mirascript/wasm",
  "version": "0.1.69",
  "author": "CloudPSS",
  "license": "MIT",
  "description": "MiraScript compiler for WebAssembly",
  "keywords": [
    "mirascript",
    "wasm",
    "webassembly",
    "compiler",
    "browser"
  ],
  "homepage": "https://mira.cloudpss.net",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CloudPSS/MiraScript.git",
    "directory": "packages/wasm"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "imports": {
    "#loader": {
      "node": "./dist/loader/node.js",
      "default": "./dist/loader/web.js"
    }
  },
  "scripts": {
    "wasm": "wasm-pack build --target web --out-dir ../../packages/wasm/lib --no-pack ../../crates/wasm",
    "watch": "nodemon -e rs,js,ts --watch ../../crates/wasm --watch ../../crates/core --watch ./src --exec 'pnpm build:dev'",
    "build:dev": "pnpm wasm --dev && tsc && rimraf lib/.gitignore",
    "build": "pnpm wasm --release && tsc && rimraf lib/.gitignore",
    "clean": "rimraf dist lib"
  },
  "devDependencies": {
    "@mirascript/constants": "workspace:~",
    "@types/node": "^26.1.1",
    "nodemon": "^3.1.14"
  }
}
