{
  "name": "@mirascript/wasm",
  "type": "module",
  "description": "MiraScript compiler for WebAssembly",
  "version": "0.1.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": "./dist/index.js",
  "scripts": {
    "wasm": "wasm-pack build --target bundler --out-dir ../../packages/wasm/lib --no-pack ../../crates/wasm",
    "build:dev": "pnpm wasm --dev && tsc",
    "build": "pnpm wasm --release && tsc",
    "clean": "rimraf dist lib"
  }
}
