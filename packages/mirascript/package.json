{
  "name": "mirascript",
  "private": true,
  "type": "module",
  "description": "An expression based scripting language.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "@mira/development": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./subtle": {
      "@mira/development": "./src/subtle.ts",
      "default": "./dist/subtle.js"
    }
  },
  "imports": {
    "#compiler/worker": {
      "@mira/development": "./src/compiler/worker.ts",
      "default": "./dist/compiler/worker.js"
    },
    "#compiler-bundle": {
      "node": "@mirascript/napi",
      "default": "@mirascript/wasm"
    }
  },
  "scripts": {
    "watch": "pnpm clean && tsc --watch",
    "build": "pnpm clean && tsc --emitDeclarationOnly && node ./esbuild.config.js",
    "clean": "rimraf dist",
    "test": "c8 ava"
  },
  "dependencies": {
    "@mirascript/napi": "workspace:~",
    "@mirascript/wasm": "workspace:~",
    "js-base64": "^3.7.8"
  },
  "devDependencies": {
    "@types/sinon": "^17.0.4",
    "ava": "^6.4.1",
    "c8": "^10.1.3",
    "sinon": "^21.0.0"
  }
}
