{
  "name": "@mirascript/mirascript",
  "version": "0.1.15",
  "author": "CloudPSS",
  "license": "MIT",
  "description": "An expression based scripting language.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": "./dist/cli/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "@mirascript/dev": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./subtle": {
      "@mirascript/dev": "./src/subtle.ts",
      "default": "./dist/subtle.js"
    },
    "./cli": {
      "@mirascript/dev": "./src/cli/index.ts",
      "default": "./dist/cli/index.js"
    }
  },
  "imports": {
    "#compiler/worker": {
      "@mirascript/dev": "./src/compiler/worker.ts",
      "default": "./dist/compiler/worker.js"
    }
  },
  "scripts": {
    "watch": "pnpm build:ts --watch",
    "build:ts": "pnpm clean && tsc",
    "build": "pnpm build:ts --emitDeclarationOnly && node ./esbuild.config.js",
    "mirascript": "node --enable-source-maps ./dist/cli/index.js",
    "clean": "rimraf dist",
    "test": "c8 ava",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "@mirascript/bindings": "workspace:~",
    "ansi-styles": "^6.2.3",
    "commander": "^14.0.2",
    "source-map-js": "^1.2.1",
    "supports-color": "^10.2.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/sinon": "^21.0.0",
    "ava": "^6.4.1",
    "c8": "^10.1.3",
    "sinon": "^21.0.0",
    "type-fest": "^5.2.0"
  }
}
