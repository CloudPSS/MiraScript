{
  "name": "mirascript",
  "private": true,
  "type": "module",
  "description": "An expression based scripting language.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "@mira/development": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./subtle": {
      "@mira/development": "./src/subtle.ts",
      "default": "./dist/subtle.js"
    }
  },
  "scripts": {
    "build": "tsc && node ./esbuild.config.js"
  },
  "dependencies": {
    "@mirascript/wasm": "workspace:*"
  }
}
