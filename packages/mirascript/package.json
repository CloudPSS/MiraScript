{
  "name": "@mirascript/mirascript",
  "version": "0.1.64",
  "author": "CloudPSS",
  "license": "MIT",
  "description": "An expression based scripting language.",
  "keywords": [
    "mirascript",
    "language",
    "compiler",
    "runtime",
    "vm"
  ],
  "homepage": "https://mira.cloudpss.net",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CloudPSS/MiraScript.git",
    "directory": "packages/mirascript"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "@mirascript/dev": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./subtle": {
      "@mirascript/dev": "./src/subtle.ts",
      "default": "./dist/subtle.js"
    },
    "./package.json": "./package.json"
  },
  "imports": {
    "#package.json": "./package.json",
    "#compiler/worker": {
      "@mirascript/dev": "./src/compiler/worker.ts",
      "default": "./dist/compiler/worker.js"
    }
  },
  "scripts": {
    "watch": "pnpm build:ts --watch",
    "build:ts": "pnpm clean && tsc",
    "build": "pnpm build:ts --emitDeclarationOnly && node ./esbuild.config.js",
    "deps": "pnpm dlx madge --circular --warning ./src",
    "clean": "rimraf dist",
    "test": "FORCE_COLOR=1 c8 ava --no-worker-threads",
    "bench": "node ./bench/index.ts"
  },
  "dependencies": {
    "@cloudpss/worker": "^0.1.11",
    "@mirascript/bindings": "workspace:~",
    "@mirascript/constants": "workspace:~",
    "source-map-js": "^1.2.1",
    "supports-color": "^10.2.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "ava": "^8.0.1",
    "c8": "^11.0.0",
    "tinybench": "^6.0.2",
    "type-fest": "^5.8.0"
  }
}
