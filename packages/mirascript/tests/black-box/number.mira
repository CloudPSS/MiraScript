t.snapshot(1, 0, -0, 0e0);
t.snapshot(1.1, -1.1);
t.snapshot(1.1e1, 1.1e-1, 1.1e+1);
t.snapshot(1_2.3_4e+5_6);
t.snapshot(0xabcdef, 0xABCDEF, 0xabcdef0, 0xab_cd_ef_12);
t.snapshot(0o123, 0o1234, 0o12345);
t.snapshot(0b101010, 0b1010101, 0b1010_1010);

t.ne(0, -0);
t.eq(0/0, nan);
t.eq(1/0, inf);
t.eq(-1/0, -inf);

t.true(nan != nan);
t.false(nan ~= nan);
t.true(nan is nan);
