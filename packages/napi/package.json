{
  "name": "@mirascript/napi",
  "version": "0.1.59",
  "author": "CloudPSS",
  "license": "MIT",
  "description": "MiraScript compiler for Node.JS",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": "./dist/index.js",
  "napi": {
    "binaryName": "mirascript",
    "targets": [
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin"
    ]
  },
  "engines": {
    "node": ">= 16"
  },
  "scripts": {
    "build": "pnpm build:docker || pnpm build:debug --release",
    "build:docker": "docker buildx build --platform amd64,arm64 -f ./Dockerfile --pull --output type=local,dest=./dist,platform-split=false ../..",
    "build:debug": "napi build --manifest-path ../../crates/node-api/Cargo.toml --output-dir dist --platform",
    "watch": "nodemon --watch ../../crates/ --ext rs --exec \"pnpm run build:debug\""
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.0",
    "@types/node": "^25.5.0",
    "nodemon": "^3.1.14"
  }
}
