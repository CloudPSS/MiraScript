{
  "name": "@mirascript/napi",
  "version": "0.1.64",
  "author": "CloudPSS",
  "license": "MIT",
  "description": "MiraScript compiler for Node.JS",
  "keywords": [
    "mirascript",
    "napi",
    "node-api",
    "compiler",
    "native"
  ],
  "homepage": "https://mira.cloudpss.net",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CloudPSS/MiraScript.git",
    "directory": "packages/napi"
  },
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": "./dist/index.js",
  "napi": {
    "binaryName": "mirascript",
    "targets": [
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin"
    ]
  },
  "engines": {
    "node": ">= 16"
  },
  "scripts": {
    "build": "pnpm run build:debug --release",
    "build:debug": "napi build --manifest-path ../../crates/napi/Cargo.toml --output-dir dist --platform",
    "watch": "nodemon --watch ../../crates/ --ext rs --exec \"pnpm run build:debug\"",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.2",
    "@types/node": "^26.0.1",
    "nodemon": "^3.1.14"
  }
}
