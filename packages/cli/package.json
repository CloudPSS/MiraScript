{
  "name": "@mirascript/cli",
  "version": "0.1.62-alpha.15",
  "author": "CloudPSS",
  "license": "MIT",
  "description": "Cli for MiraScript, an expression based scripting language.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "mirascript": "./cli.js"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "@mirascript/dev": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "imports": {
    "#package.json": "./package.json"
  },
  "scripts": {
    "watch": "pnpm build --watch",
    "build": "pnpm clean && node ./esbuild.config.js",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "@mirascript/bindings": "workspace:~",
    "@mirascript/mirascript": "workspace:~",
    "ansi-styles": "^6.2.3",
    "commander": "^14.0.3",
    "supports-color": "^10.2.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "type-fest": "^5.5.0"
  }
}
