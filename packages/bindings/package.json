{
  "name": "@mirascript/bindings",
  "version": "0.1.62",
  "author": "CloudPSS",
  "license": "MIT",
  "description": "MiraScript compiler bindings",
  "keywords": [
    "mirascript",
    "compiler",
    "bindings",
    "napi",
    "wasm"
  ],
  "homepage": "https://mira.cloudpss.net",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CloudPSS/MiraScript.git",
    "directory": "packages/bindings"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./wasm": "./dist/wasm.js",
    "./napi": "./dist/napi.js"
  },
  "imports": {
    "#bundle": {
      "node": "./dist/napi.js",
      "default": "./dist/wasm.js"
    }
  },
  "scripts": {
    "watch": "pnpm build --watch",
    "build": "pnpm clean && tsc",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@mirascript/napi": "workspace:~",
    "@mirascript/wasm": "workspace:~"
  },
  "devDependencies": {
    "@types/node": "^26.0.1"
  }
}
