{
  "name": "@mirascript/website",
  "version": "0.1.55",
  "homepage": "https://mira.cloudpss.net",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start --no-open",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve --no-open",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "extract-code": "node ./scripts/extract-code.mjs",
    "extract-doc": "node ./scripts/extract-doc.mjs",
    "prebuild": "pnpm run extract-code && pnpm run extract-doc",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@docusaurus/core": "3.9.2",
    "@docusaurus/preset-classic": "3.9.2",
    "@easyops-cn/docusaurus-search-local": "^0.55.1",
    "@mirascript/bindings": "workspace:~",
    "@mirascript/mirascript": "workspace:~",
    "@mirascript/monaco": "workspace:~",
    "@monaco-editor/react": "^4.7.0",
    "@private/monaco-editor": "^0.0.70",
    "fflate": "^0.8.2",
    "js-base64": "^3.7.8",
    "remark-directive": "^4.0.0",
    "remark-extended-table": "^2.0.3",
    "remark-gfm": "^4.0.1",
    "remark-ins": "^1.2.3",
    "remark-join-cjk-lines": "^1.0.14"
  },
  "devDependencies": {
    "@docusaurus/faster": "^3.9.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
