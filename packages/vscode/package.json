{
  "name": "@mirascript/vscode",
  "displayName": "MiraScript",
  "description": "MiraScript Language Support",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "mirascript",
        "extensions": [
          ".mira"
        ],
        "aliases": [
          "MiraScript",
          "mirascript",
          "mira"
        ],
        "mimetypes": [
          "text/x-mirascript"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "mirascript-template",
        "extensions": [
          ".miratpl"
        ],
        "aliases": [
          "MiraScriptTemplate",
          "mirascript-template",
          "miratpl"
        ],
        "mimetypes": [
          "text/x-mirascript-template"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "mirascript",
        "scopeName": "source.mira",
        "path": "./syntaxes/mirascript.tmLanguage.json",
        "tokenTypes": {
          "meta.template.expression.mira": "other"
        }
      },
      {
        "language": "mirascript-template",
        "scopeName": "source.miratpl",
        "path": "./syntaxes/mirascript-template.tmLanguage.json"
      }
    ]
  }
}
