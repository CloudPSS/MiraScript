{
  "name": "@mirascript/vscode",
  "version": "0.1.67",
  "author": "CloudPSS",
  "publisher": "CloudPSS",
  "license": "MIT",
  "displayName": "MiraScript",
  "description": "MiraScript language support for Visual Studio Code.",
  "homepage": "https://mira.cloudpss.net",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CloudPSS/MiraScript.git",
    "directory": "packages/vscode"
  },
  "icon": "./dist/icon.png",
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "private": true,
  "type": "module",
  "main": "./dist/main.mjs",
  "browser": "./dist/browser.cjs",
  "engines": {
    "vscode": "^1.80.0"
  },
  "imports": {
    "#loader": {
      "web-extension": "./src/loader/browser.ts",
      "default": "./src/loader/index.ts"
    }
  },
  "scripts": {
    "build:icon": "node scripts/icon.js",
    "build:language-configuration": "node scripts/language-configuration.js",
    "build:language": "node scripts/language.js",
    "build:esbuild": "tsc --noEmit && node ./esbuild.config.js",
    "build": "pnpm build:icon && pnpm build:language-configuration && pnpm build:language && pnpm build:esbuild",
    "watch:language": "nodemon --watch scripts --exec 'pnpm build:language' --ext yaml",
    "watch:esbuild": "nodemon --watch esbuild.config.js --watch src --ext js,ts --exec 'pnpm build:esbuild'",
    "watch:ts": "rimraf ./dist && tsc --watch",
    "clean": "rimraf dist build media syntaxes language-configuration.json"
  },
  "dependencies": {
    "@mirascript/mirascript": "workspace:~",
    "@mirascript/monaco": "workspace:~",
    "@mirascript/wasm": "workspace:~"
  },
  "devDependencies": {
    "@private/monaco-editor": "^0.0.71",
    "@types/node": "^26.1.1",
    "@types/vscode": "1.80.0",
    "js-yaml": "^5.2.1",
    "nodemon": "^3.1.14",
    "svg2png-wasm": "^1.4.1"
  },
  "contributes": {
    "markdown.previewScripts": [
      "./media/markdown-preview.js"
    ],
    "languages": [
      {
        "id": "mirascript",
        "extensions": [
          ".mira"
        ],
        "aliases": [
          "MiraScript",
          "mirascript",
          "mira"
        ],
        "mimetypes": [
          "text/x-mirascript"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/mira-light.svg",
          "dark": "./icons/mira-dark.svg"
        }
      },
      {
        "id": "mirascript-doc",
        "extensions": [],
        "aliases": [],
        "mimetypes": [
          "text/x-mirascript-doc"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/mira-light.svg",
          "dark": "./icons/mira-dark.svg"
        }
      },
      {
        "id": "mirascript-template",
        "extensions": [
          ".miratpl"
        ],
        "aliases": [
          "MiraScriptTemplate",
          "mirascript-template",
          "miratpl"
        ],
        "mimetypes": [
          "text/x-mirascript-template"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/miratpl-light.svg",
          "dark": "./icons/miratpl-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "mirascript",
        "scopeName": "source.mira",
        "path": "./syntaxes/mira.tmLanguage.json",
        "tokenTypes": {
          "punctuation.definition.template-expression": "other"
        }
      },
      {
        "language": "mirascript-doc",
        "scopeName": "source.mira",
        "path": "./syntaxes/mira.tmLanguage.json",
        "tokenTypes": {
          "punctuation.definition.template-expression": "other"
        }
      },
      {
        "scopeName": "markdown.mira.codeblock",
        "path": "./syntaxes/mira-markdown.tmLanguage.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.mira": "mirascript"
        }
      },
      {
        "language": "mirascript-template",
        "scopeName": "string.miratpl",
        "path": "./syntaxes/miratpl.tmLanguage.json",
        "tokenTypes": {
          "punctuation.definition.template-expression": "other"
        }
      },
      {
        "scopeName": "markdown.miratpl.codeblock",
        "path": "./syntaxes/miratpl-markdown.tmLanguage.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.miratpl": "mirascript-template"
        }
      }
    ]
  }
}
