{
  "name": "@mirascript/vscode",
  "version": "0.1.39",
  "author": "CloudPSS",
  "publisher": "CloudPSS",
  "license": "MIT",
  "displayName": "MiraScript",
  "description": "MiraScript language support for Visual Studio Code.",
  "categories": [
    "Programming Languages"
  ],
  "private": true,
  "type": "module",
  "main": "./dist/main.js",
  "engines": {
    "vscode": "^1.90.0"
  },
  "scripts": {
    "build:language-configuration": "node scripts/language-configuration.js",
    "build:language": "node scripts/language.js",
    "build:esbuild": "node ./esbuild.config.js",
    "build": "pnpm build:language-configuration && pnpm build:language && pnpm build:esbuild",
    "watch:language": "nodemon --watch scripts --exec 'pnpm build:language' --ext yaml",
    "watch:esbuild": "nodemon --watch esbuild.config.js --watch src --ext js,ts --exec 'pnpm build:esbuild'",
    "watch:ts": "rimraf ./dist && tsc --watch"
  },
  "dependencies": {
    "@mirascript/wasm": "workspace:~"
  },
  "devDependencies": {
    "@mirascript/mirascript": "workspace:~",
    "@mirascript/monaco": "workspace:~",
    "@private/monaco-editor": "^0.0.63",
    "@types/node": "^25.0.10",
    "@types/vscode": "^1.108.1",
    "cosmiconfig": "^9.0.0",
    "js-yaml": "^4.1.1",
    "nodemon": "^3.1.11"
  },
  "contributes": {
    "markdown.previewScripts": [
      "./media/markdown-preview.js"
    ],
    "languages": [
      {
        "id": "mirascript",
        "extensions": [
          ".mira"
        ],
        "aliases": [
          "MiraScript",
          "mirascript",
          "mira"
        ],
        "mimetypes": [
          "text/x-mirascript"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/mira-light.svg",
          "dark": "./icons/mira-dark.svg"
        }
      },
      {
        "id": "mirascript-doc",
        "extensions": [],
        "aliases": [],
        "mimetypes": [
          "text/x-mirascript-doc"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/mira-light.svg",
          "dark": "./icons/mira-dark.svg"
        }
      },
      {
        "id": "mirascript-template",
        "extensions": [
          ".miratpl"
        ],
        "aliases": [
          "MiraScriptTemplate",
          "mirascript-template",
          "miratpl"
        ],
        "mimetypes": [
          "text/x-mirascript-template"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/miratpl-light.svg",
          "dark": "./icons/miratpl-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "mirascript",
        "scopeName": "source.mira",
        "path": "./syntaxes/mira.tmLanguage.json",
        "tokenTypes": {
          "punctuation.definition.template-expression": "other"
        }
      },
      {
        "language": "mirascript-doc",
        "scopeName": "source.mira",
        "path": "./syntaxes/mira.tmLanguage.json",
        "tokenTypes": {
          "punctuation.definition.template-expression": "other"
        }
      },
      {
        "scopeName": "markdown.mira.codeblock",
        "path": "./syntaxes/mira-markdown.tmLanguage.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.mira": "mirascript"
        }
      },
      {
        "language": "mirascript-template",
        "scopeName": "string.miratpl",
        "path": "./syntaxes/miratpl.tmLanguage.json",
        "tokenTypes": {
          "punctuation.definition.template-expression": "other"
        }
      },
      {
        "scopeName": "markdown.miratpl.codeblock",
        "path": "./syntaxes/miratpl-markdown.tmLanguage.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.miratpl": "mirascript-template"
        }
      }
    ]
  }
}
