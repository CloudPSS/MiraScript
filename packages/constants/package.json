{
  "name": "@mirascript/constants",
  "version": "0.1.62-alpha.22",
  "author": "CloudPSS",
  "license": "MIT",
  "description": "MiraScript constants",
  "keywords": [
    "mirascript",
    "constants",
    "keywords",
    "diagnostics",
    "compiler"
  ],
  "homepage": "https://mira.cloudpss.net",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CloudPSS/MiraScript.git",
    "directory": "packages/constants"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "wasm": "wasm-pack build --target nodejs --out-dir ../../packages/constants/lib ../../crates/constants",
    "watch": "nodemon -e rs,js,ts --watch ../../crates/constants --watch ../../crates/core --exec 'pnpm build'",
    "build": "pnpm wasm --dev && node ./scripts/build.ts && tsc",
    "clean": "rimraf dist lib"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "nodemon": "^3.1.14"
  }
}
