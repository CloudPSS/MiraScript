{
  "name": "@mirascript/monaco",
  "version": "0.1.66",
  "author": "CloudPSS",
  "license": "MIT",
  "description": "Monaco Editor integration for Mirascript.",
  "keywords": [
    "mirascript",
    "monaco",
    "editor",
    "language-service",
    "lsp"
  ],
  "homepage": "https://mira.cloudpss.net",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CloudPSS/MiraScript.git",
    "directory": "packages/monaco"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "@mirascript/dev": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./basic": {
      "@mirascript/dev": "./src/basic/index.ts",
      "default": "./dist/basic/index.js"
    },
    "./lsp": {
      "@mirascript/dev": "./src/lsp/index.ts",
      "default": "./dist/lsp/index.js"
    }
  },
  "imports": {
    "#lsp/worker": {
      "@mirascript/dev": "./src/lsp/worker.ts",
      "default": "./dist/lsp/worker.js"
    }
  },
  "scripts": {
    "build": "pnpm clean && tsc && node ./esbuild.config.js",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@mirascript/bindings": "workspace:~",
    "@mirascript/constants": "workspace:~",
    "@mirascript/help": "workspace:~",
    "@mirascript/mirascript": "workspace:~"
  },
  "peerDependencies": {
    "monaco-editor": ">= 0.0.40"
  },
  "peerDependenciesMeta": {
    "monaco-editor": {
      "optional": true
    }
  },
  "devDependencies": {
    "type-fest": "^5.8.0"
  }
}
