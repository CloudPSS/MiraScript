{
  // 如果使用其他版本 TS，使用类似 "extends": "@cloudpss/tsconfig/4.2" 引入
  "extends": "../../../tsconfig.json",

  "compilerOptions": {
    "rootDir": "./..",
    "noEmit": true,
    "erasableSyntaxOnly": true,
    "module": "NodeNext",
    "rewriteRelativeImportExtensions": true,
    "types": ["node"]
  },

  "include": ["./**/*.ts"]
}
