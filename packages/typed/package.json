{
  "name": "@mirascript/typed",
  "version": "0.1.69",
  "author": "CloudPSS",
  "license": "MIT",
  "description": "Parse MiraScript type definitions and generate TypeScript types / JSON schemas.",
  "keywords": [
    "mirascript",
    "json-schema",
    "types"
  ],
  "homepage": "https://mira.cloudpss.net",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CloudPSS/MiraScript.git",
    "directory": "packages/typed"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "peggy src/type.peggy --multi-output ./dist --dts --format es --source-map && tsc",
    "clean": "rimraf dist",
    "test": "c8 ava --no-worker-threads"
  },
  "devDependencies": {
    "@mirascript/mirascript": "workspace:~",
    "@types/node": "^26.1.1",
    "ava": "^8.0.1",
    "c8": "^11.0.0",
    "js-yaml": "^5.2.1",
    "peggy": "^5.1.0"
  },
  "dependencies": {
    "@mirascript/constants": "workspace:~",
    "json-schema-typed": "^8.0.2"
  }
}
