    "@cloudpss/lint-staged-config": "^3.0.32",
    "@cloudpss/prettier-config": "^3.0.32",
    "@cloudpss/tsconfig": "^3.0.32",
    "better-typescript-lib": "^2.12.0",
    "esbuild": "^0.27.1",
    "husky": "^9.1.7",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3"
  }
}
