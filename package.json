{
  "name": "mirascript",
  "version": "0.1.62-alpha.23",
  "private": true,
  "packageManager": "pnpm@11.0.9",
  "type": "module",
  "engines": {
    "node": ">= 20"
  },
  "scripts": {
    "prepare": "husky || echo Failed to initialize husky",
    "format:mira": "pnpm exec mirascript format --write './**/*.mira'",
    "format:rs": "cargo fmt --all",
    "format:ts": "prettier --cache --cache-strategy content --write .",
    "format": "pnpm run format:mira && pnpm run format:rs && pnpm run format:ts",
    "lint": "eslint --cache --cache-location node_modules/.cache/eslint/ --cache-strategy content"
  },
  "prettier": "@cloudpss/prettier-config",
  "commitlint": {
    "extends": "@cloudpss"
  },
  "devDependencies": {
    "@cloudpss/commitlint-config": "catalog:",
    "@cloudpss/eslint-config": "catalog:",
    "@cloudpss/lint-staged-config": "catalog:",
    "@cloudpss/prettier-config": "catalog:",
    "@cloudpss/tsconfig": "catalog:",
    "@mirascript/cli": "workspace:*",
    "better-typescript-lib": "^2.12.0",
    "esbuild": "^0.28.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  }
}
